  <style>
    :root{
      --black:#030506;
      --dark:#080c10;
      --card:#0d1117;
      --border:rgba(255,255,255,0.06);
      --steel:#1e2d3d;
      --blue:#0a84ff;
      --blue-dim:rgba(10,132,255,0.15);
      --cyan:#30d5c8;
      --white:#e8edf2;
      --muted:rgba(232,237,242,0.4);
      --red:#ff3b30;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{background:var(--black);color:var(--white);font-family:'Inter',sans-serif;font-weight:300;overflow-x:hidden;}

    /* scanline effect */
    body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(255,255,255,0.008) 2px,rgba(255,255,255,0.008) 4px);pointer-events:none;z-index:9998;}

    /* NAV */
    nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:1rem 3rem;display:flex;align-items:center;justify-content:space-between;background:rgba(3,5,6,0.9);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);}
    .nav-logo{font-family:'Rajdhani',sans-serif;font-weight:700;font-size:1.4rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--white);}
    .nav-logo span{color:var(--blue);}
    .nav-links{display:flex;gap:2.5rem;list-style:none;}
    .nav-links a{color:var(--muted);text-decoration:none;font-size:0.78rem;letter-spacing:0.12em;text-transform:uppercase;font-family:'Rajdhani',sans-serif;font-weight:600;transition:color 0.3s;}
    .nav-links a:hover{color:var(--cyan);}
    .nav-cta{background:var(--blue);color:white!important;padding:0.45rem 1.3rem;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);}
    .nav-cta:hover{background:#1a8fff!important;}

    /* HERO */
    #hero{min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;padding:8rem 3rem 4rem;}
    .hero-grid-bg{position:absolute;inset:0;background-image:linear-gradient(rgba(10,132,255,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(10,132,255,0.04) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;}
    .hero-glow{position:absolute;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(10,132,255,0.12),transparent 70%);top:50%;left:60%;transform:translate(-50%,-50%);}
    .hero-content{position:relative;z-index:2;max-width:780px;}
    .status-bar{display:flex;align-items:center;gap:1rem;margin-bottom:2rem;opacity:0;animation:fadeUp 0.8s 0.2s forwards;}
    .status-dot{width:8px;height:8px;border-radius:50%;background:var(--cyan);animation:blink 2s ease-in-out infinite;}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:0.3}}
    .status-text{font-family:'Share Tech Mono',monospace;font-size:0.72rem;letter-spacing:0.15em;color:var(--cyan);}
    .hero-title{font-family:'Rajdhani',sans-serif;font-weight:700;font-size:clamp(3.5rem,9vw,8rem);line-height:0.9;letter-spacing:0.03em;text-transform:uppercase;margin-bottom:1.5rem;opacity:0;animation:fadeUp 0.8s 0.4s forwards;}
    .hero-title .blue{color:var(--blue);}
    .hero-title .outline{-webkit-text-stroke:1px rgba(232,237,242,0.3);color:transparent;}
    .hero-desc{font-size:1rem;color:var(--muted);line-height:1.85;max-width:520px;margin-bottom:2.5rem;opacity:0;animation:fadeUp 0.8s 0.6s forwards;}
    .hero-tags{display:flex;gap:0.8rem;flex-wrap:wrap;margin-bottom:2.5rem;opacity:0;animation:fadeUp 0.8s 0.7s forwards;}
    .tag{font-family:'Rajdhani',sans-serif;font-weight:600;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;padding:0.3rem 0.9rem;background:var(--blue-dim);color:var(--blue);border:1px solid rgba(10,132,255,0.25);}
    .hero-btns{display:flex;gap:1rem;flex-wrap:wrap;opacity:0;animation:fadeUp 0.8s 0.8s forwards;}
    .btn-blue{background:var(--blue);color:white;padding:0.9rem 2.2rem;text-decoration:none;font-family:'Rajdhani',sans-serif;font-weight:700;font-size:1rem;letter-spacing:0.12em;text-transform:uppercase;clip-path:polygon(10px 0%,100% 0%,calc(100% - 10px) 100%,0% 100%);transition:background 0.3s,transform 0.3s;}
    .btn-blue:hover{background:#1a8fff;transform:translateY(-2px);}
    .btn-frame{background:transparent;color:var(--white);padding:0.9rem 2.2rem;text-decoration:none;font-family:'Rajdhani',sans-serif;font-weight:600;font-size:1rem;letter-spacing:0.12em;text-transform:uppercase;border:1px solid rgba(232,237,242,0.2);clip-path:polygon(10px 0%,100% 0%,calc(100% - 10px) 100%,0% 100%);transition:border-color 0.3s;}
    .btn-frame:hover{border-color:var(--cyan);color:var(--cyan);}
    .hero-number{position:absolute;bottom:2rem;right:3rem;z-index:2;text-align:right;opacity:0;animation:fadeUp 0.8s 1s forwards;}
    .hero-number a{font-family:'Share Tech Mono',monospace;font-size:1.1rem;color:var(--cyan);text-decoration:none;letter-spacing:0.1em;}
    .hero-number span{display:block;font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--muted);margin-bottom:0.2rem;}

    /* MARQUEE */
    .marquee-wrap{overflow:hidden;background:var(--blue);padding:0.65rem 0;}
    .marquee-track{display:flex;gap:2.5rem;animation:marquee 20s linear infinite;width:max-content;}
    .marquee-item{font-family:'Rajdhani',sans-serif;font-weight:700;font-size:0.85rem;letter-spacing:0.18em;text-transform:uppercase;color:white;white-space:nowrap;}
    .m-dot{display:inline-block;width:4px;height:4px;background:rgba(255,255,255,0.4);border-radius:50%;margin:0 0.4rem;vertical-align:middle;}
    @keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}

    /* SECTION */
    .section-inner{max-width:1200px;margin:0 auto;padding:6rem 2rem;}
    .section-label{font-family:'Share Tech Mono',monospace;font-size:0.68rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--cyan);margin-bottom:0.8rem;}
    .section-title{font-family:'Rajdhani',sans-serif;font-weight:700;font-size:clamp(2.5rem,5vw,4.5rem);line-height:1;letter-spacing:0.04em;text-transform:uppercase;margin-bottom:1rem;}
    .section-desc{color:var(--muted);font-size:0.93rem;line-height:1.85;max-width:540px;}
    .divider{height:1px;background:linear-gradient(to right,transparent,var(--blue),transparent);opacity:0.2;max-width:1200px;margin:0 auto;}

    /* SERVICES */
    #services{background:var(--dark);}
    .services-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1rem;margin-top:3.5rem;}
    .svc-card{background:var(--card);border:1px solid var(--border);padding:1.8rem;position:relative;overflow:hidden;transition:border-color 0.3s,transform 0.3s;}
    .svc-card::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--blue);opacity:0;transition:opacity 0.3s;}
    .svc-card:hover{border-color:rgba(10,132,255,0.3);transform:translateX(4px);}
    .svc-card:hover::before{opacity:1;}
    .svc-icon{font-size:1.6rem;margin-bottom:1rem;}
    .svc-name{font-family:'Rajdhani',sans-serif;font-weight:700;font-size:1.05rem;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:0.5rem;}
    .svc-desc{font-size:0.82rem;color:var(--muted);line-height:1.7;}

    /* WHY */
    #why{background:var(--black);}
    .why-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;margin-top:3rem;}
    .why-visual{background:var(--card);border:1px solid var(--border);height:400px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;}
    .why-shield{font-size:8rem;position:relative;z-index:2;filter:drop-shadow(0 0 40px rgba(10,132,255,0.5));}
    .why-ring{position:absolute;width:300px;height:300px;border-radius:50%;border:1px solid rgba(10,132,255,0.15);animation:spin 20s linear infinite;}
    .why-ring2{position:absolute;width:220px;height:220px;border-radius:50%;border:1px solid rgba(48,213,200,0.1);animation:spin 14s linear infinite reverse;}
    @keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
    .why-features{display:flex;flex-direction:column;gap:1rem;}
    .why-feat{display:flex;gap:1rem;align-items:flex-start;padding:1.2rem;background:var(--card);border:1px solid var(--border);transition:border-color 0.3s;}
    .why-feat:hover{border-color:rgba(10,132,255,0.3);}
    .wf-icon{font-size:1.3rem;flex-shrink:0;}
    .wf-title{font-family:'Rajdhani',sans-serif;font-weight:700;font-size:0.95rem;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:0.2rem;}
    .wf-desc{font-size:0.82rem;color:var(--muted);line-height:1.6;}

    /* STATS */
    #stats{background:linear-gradient(135deg,var(--blue),#0060cc);}
    .stats-inner{max-width:1200px;margin:0 auto;padding:4rem 2rem;display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;text-align:center;}
    .stat-num{font-family:'Rajdhani',sans-serif;font-weight:700;font-size:3.5rem;color:white;line-height:1;}
    .stat-label{font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6);margin-top:0.3rem;font-family:'Share Tech Mono',monospace;}

    /* CONTACT */
    #contact{background:var(--dark);}
    .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;margin-top:3rem;}
    .contact-card{background:var(--card);border:1px solid var(--border);padding:1.5rem;display:flex;gap:1.2rem;align-items:flex-start;transition:border-color 0.3s;margin-bottom:1rem;}
