    .cc-icon{font-size:1.3rem;flex-shrink:0;}
    .cc-label{font-family:'Share Tech Mono',monospace;font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--cyan);margin-bottom:0.2rem;}
    .cc-val{font-size:0.95rem;}
    .cc-val a{color:var(--white);text-decoration:none;}
    .cc-val a:hover{color:var(--cyan);}
    .emergency-box{background:rgba(10,132,255,0.06);border:1px solid rgba(10,132,255,0.2);padding:2rem;}
    .emg-title{font-family:'Rajdhani',sans-serif;font-weight:700;font-size:1.1rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--blue);margin-bottom:0.8rem;}
    .emg-text{font-size:0.85rem;color:var(--muted);line-height:1.8;}
    .emg-number{font-family:'Share Tech Mono',monospace;font-size:1.6rem;color:var(--cyan);margin:1rem 0;display:block;}

    /* FOOTER */
