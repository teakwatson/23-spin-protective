    @media(max-width:900px){nav{padding:1rem 1.5rem;}.nav-links{display:none;}.stats-inner{grid-template-columns:repeat(2,1fr);}.contact-grid{grid-template-columns:1fr;}.why-grid{grid-template-columns:1fr;}.why-visual{height:220px;}}
